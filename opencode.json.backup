{
  "$schema": "https://opencode.ai/config.json",
  "theme": "opencode",
  "autoupdate": true,
  "provider": {
    "openrouter": {
      "options": {
        "baseURL": "https://api.zveno.ai/v1"
      }
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "./"
      ],
      "enabled": true
    }
  },
  "instructions": [
    "./AGENTS.md"
  ],
  "agent": {
    "plan": {
      "model": "openrouter/moonshotai/kimi-k2.5",
      "instructions": [
        "./.clinerules/plan.md",
        "./.clinerules/workflows/plan.md",
        "./AGENTS.md"
      ]
    },
    "build": {
      "model": "openrouter/minimax/minimax-m2.1",
      "instructions": [
        "./.clinerules/build.md",
        "./.clinerules/workflows/build.md",
        "./AGENTS.md"
      ]
    }
  }
}
